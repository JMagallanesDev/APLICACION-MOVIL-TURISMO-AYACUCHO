# ============================================================
# Backend — copiar a .env.local para desarrollo (RNF-17:
# secrets NUNCA en Git; en producción van en el panel de Railway)
# ============================================================

SPRING_PROFILES_ACTIVE=dev

# PostgreSQL (local: Docker Compose / prod: Supabase Session Pooler)
DATABASE_URL=jdbc:postgresql://localhost:5432/huamanga
DATABASE_USER=huamanga
DATABASE_PASSWORD=huamanga_dev

# Redis (local: Docker Compose / prod: Upstash con rediss://)
REDIS_URL=redis://localhost:6379

# Auth (Sprint 2): generar el secreto con  openssl rand -base64 32
# En producción JWT_SECRET es OBLIGATORIO (el default solo sirve en dev)
JWT_SECRET=
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000
COOKIE_SECURE=false
RATE_LIMIT_POR_MINUTO=100

# Revalidación ISR (sección 5.5): URL del webhook en Vercel + secreto compartido
# En dev pueden quedar vacíos (no-op)
REVALIDATE_WEBHOOK_URL=
REVALIDATE_SECRET=

# Sprints posteriores
# CLOUDINARY_URL=
# OPENWEATHER_API_KEY=
# CORS_ALLOWED_ORIGINS=http://localhost:3000
